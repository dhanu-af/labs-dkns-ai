# Postgres connection strings (Neon or any Postgres provider).
# DATABASE_URL should be the pooled connection string used at runtime.
# DATABASE_URL_UNPOOLED should be the direct connection string, used by Prisma Migrate.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://user:password@host/dbname?sslmode=require"

# Site login. Accounts live in the User table (see /admin/users), but the
# very first SUPER_ADMIN account has nowhere to be created from -- these two
# vars bootstrap it via the seed script (see prisma/seed.ts). Safe to leave
# set permanently; the seed re-syncs this account's password on every
# deploy, so change the value here to rotate it.
# SESSION_SECRET should be a long random string, unique per environment.
SESSION_SECRET="replace-with-a-long-random-string"
SITE_USERNAME="admin"
SITE_PASSWORD="replace-with-a-strong-password"
