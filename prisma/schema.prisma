generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// ---------------------------------------------------------------------------
// Accounts
// ---------------------------------------------------------------------------

enum UserRole {
  SUPER_ADMIN
  EDITOR
  VIEWER
}

// SUPER_ADMIN and EDITOR can edit content; only SUPER_ADMIN can manage other
// accounts (see requireSuperAdmin() in lib/auth.ts). VIEWER is read-only: no
// edit access, no /admin/* pages, no document downloads (requireEditorOrAbove()).
model User {
  id                 String   @id @default(cuid())
  username           String   @unique
  passwordHash       String
  role               UserRole @default(EDITOR)
  mustChangePassword Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Shared taxonomy
// ---------------------------------------------------------------------------

enum CategoryType {
  EQUIPMENT
  METHOD
  SOP
  DIRECTORY
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// Two-level category tree (group -> subcategory) shared by every module that
// needs a browsable taxonomy, per the sitemap's "Overview / Category Index"
// pattern (2.1, 3.1, 4.1). New modules reuse this instead of growing their
// own bespoke category tables.
model Category {
  id          String       @id @default(cuid())
  type        CategoryType
  slug        String
  name        String
  description String?
  order       Int          @default(0)
  parentId    String?
  parent      Category?    @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[]   @relation("CategoryHierarchy")

  equipment         Equipment[]
  methods           Method[]
  sops              Sop[]
  directoryListings DirectoryListing[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([type, slug])
  @@index([type, parentId])
}

// Cross-linkable reference used by the Resources > Standards & Regulations
// Library (7.5) and cited from Equipment/Method detail pages.
model StandardReference {
  id      String  @id @default(cuid())
  code    String  @unique // e.g. "ISO/IEC 17025", "ASTM E11"
  title   String
  summary String?
  url     String?
  region  String?

  equipment Equipment[]
  methods   Method[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// 2. Equipment & Instruments
// ---------------------------------------------------------------------------

// Fields map directly onto the 2.4 "Equipment page template" sections.
model Equipment {
  id     String        @id @default(cuid())
  slug   String        @unique
  name   String
  status ContentStatus @default(PUBLISHED)

  summary          String // used in listings, search results, and cards
  overview         String // working principle
  specifications   Json? // structured spec-sheet key/value pairs
  applications     String?
  manufacturers    Json? // [{ name, models: string[] }]
  maintenanceNotes String?
  safetyNotes      String?
  buyingGuide      String?
  coverImageUrl    String?

  categoryId String
  category   Category            @relation(fields: [categoryId], references: [id])
  standards  StandardReference[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([status])
}

// ---------------------------------------------------------------------------
// 3. Methods & Techniques
// ---------------------------------------------------------------------------

// Fields map directly onto the 3.6 "Method page template" sections.
model Method {
  id     String        @id @default(cuid())
  slug   String        @unique
  name   String
  status ContentStatus @default(PUBLISHED)

  summary           String
  principle         String
  procedure         String // step-by-step, stored as markdown
  requiredEquipment String?
  applications      String?
  troubleshooting   String?

  categoryId String
  category   Category            @relation(fields: [categoryId], references: [id])
  standards  StandardReference[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([status])
}

// ---------------------------------------------------------------------------
// 4. SOPs & Procedures (Phase 2)
// ---------------------------------------------------------------------------

model Sop {
  id      String        @id @default(cuid())
  slug    String        @unique
  title   String
  status  ContentStatus @default(DRAFT)
  version String        @default("1.0")

  summary        String
  body           String // full SOP text/markdown
  fileUrl        String? // downloadable template asset
  approvedAt     DateTime?
  revisionNotes  String?

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([status])
}

// ---------------------------------------------------------------------------
// 5. Lab Management & 6. Safety & Compliance (Phase 1 basics now, Phase 2 depth later)
// ---------------------------------------------------------------------------

enum GuideSection {
  LAB_MANAGEMENT
  SAFETY
  ABOUT
}

// Generic informational/guide page used by the many small, mostly-static
// subsections under Lab Management (5.1-5.4) and Safety & Compliance
// (6.1-6.4), plus the About/Community pages (10). New topics are added as
// rows, not new models -- keeps the schema from sprawling as Phase 2/3 fill in.
model GuidePage {
  id      String        @id @default(cuid())
  section GuideSection
  slug    String
  title   String
  summary String?
  body    String
  order   Int           @default(0)
  region  String? // for "Regulatory Standards by Region" (6.2) variants
  status  ContentStatus @default(PUBLISHED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([section, slug])
  @@index([section, status])
}

// ---------------------------------------------------------------------------
// 8. News & Insights (Blog) (Phase 3)
// ---------------------------------------------------------------------------

enum ArticleCategory {
  INDUSTRY_TRENDS
  NEW_EQUIPMENT
  REGULATORY_UPDATES
  CASE_STUDIES
}

model Article {
  id     String        @id @default(cuid())
  slug   String        @unique
  title  String
  status ContentStatus @default(DRAFT)

  summary     String
  body        String
  category    ArticleCategory
  author      String?
  publishedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category, status])
}

// ---------------------------------------------------------------------------
// 9. Directory (Phase 2/3)
// ---------------------------------------------------------------------------

enum DirectoryListingType {
  MANUFACTURER
  TESTING_BODY
  TRAINING_PROVIDER
}

model DirectoryListing {
  id     String               @id @default(cuid())
  slug   String               @unique
  name   String
  type   DirectoryListingType
  status ContentStatus        @default(DRAFT)

  description  String?
  website      String?
  contactEmail String?
  region       String?

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type, status])
}

// ---------------------------------------------------------------------------
// 7. Resources & Tools
// ---------------------------------------------------------------------------

// 7.3 Glossary of Terms
model GlossaryTerm {
  id         String  @id @default(cuid())
  term       String
  slug       String  @unique
  definition String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Ask Nanduni — rule-based knowledge-base Q&A (not an LLM call: a curated
// KB scored against the question by keyword/token overlap, same mechanism as
// "Dhanu AI" on the BlendCaps Ops Platform, adapted for lab content).
// ---------------------------------------------------------------------------

enum KbCategory {
  EQUIPMENT_TROUBLESHOOTING
  METHOD_TROUBLESHOOTING
  CALIBRATION
  SAMPLE_PREP
  QUALITY_CONTROL
  METHOD_DEVELOPMENT
  GMP_GLP_COMPLIANCE
  SAFETY
  DATA_ANALYSIS
  GENERAL
}

model KnowledgeEntry {
  id       String     @id @default(cuid())
  slug     String     @unique
  category KbCategory
  title    String
  keywords String
  cause    String?
  answer   String
  source   String?
  order    Int        @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
}

// One row per question asked, so admins can see what's being asked (and
// with what confidence) to prioritize expanding the knowledge base.
model KbQuestionLog {
  id          String   @id @default(cuid())
  question    String
  matchedId   String?
  matchTitle  String?
  matchScore  Float?
  askedByName String

  createdAt DateTime @default(now())

  @@index([createdAt])
}
